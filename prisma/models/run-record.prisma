model RunRecord {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], map: "run_record_user_id_fkey")
  userId    String
  startTime DateTime
  endTime   DateTime?
  duration  Int       @default(0)
  distance  Float     @default(0)
  avgPace   String    @default("")
  createdAt DateTime  @db.Timestamp(3)
  updatedAt DateTime  @db.Timestamp(3)

  @@map("run_record")
}
