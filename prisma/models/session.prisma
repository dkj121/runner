model Session {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], map: "session_user_id_fkey")
  userId    String
  token     String   @unique
  expiresAt DateTime @db.Timestamp(3)
  ipAddress String?
  userAgent String?
  createdAt DateTime @db.Timestamp(3)
  updatedAt DateTime @db.Timestamp(3)

  @@map("session")
}
