enum PlayGroundVisibility {
  PRIVATE
  PUBLIC
}

model PlayGround {
  id          String                 @id @default(cuid())
  name        String
  visibility  PlayGroundVisibility
  users       PlayGroundUser[]
  callRecords PlayGroundCallRecord[]
  createdAt   DateTime               @db.Timestamp(3)
  updatedAt   DateTime               @db.Timestamp(3)

  @@index([name], map: "idx_playground_name")
  @@map("playground")
}
