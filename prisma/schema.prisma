// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id              String           @id
  name            String
  email           String           @unique
  emailVerified   Boolean
  image           String?
  createdAt       DateTime         @db.Timestamp(3)
  updatedAt       DateTime         @db.Timestamp(3)
  sessions        Session[]
  accounts        Account[]
  playGroundUsers PlayGroundUser[]

  @@map("user")
}

model Session {
  id        String   @id
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  token     String   @unique
  expiresAt DateTime @db.Timestamp(3)
  ipAddress String?
  userAgent String?
  createdAt DateTime @db.Timestamp(3)
  updatedAt DateTime @db.Timestamp(3)

  @@map("session")
}

model Account {
  id                    String    @id
  user                  User      @relation(fields: [userId], references: [id])
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime? @db.Timestamp(3)
  refreshTokenExpiresAt DateTime? @db.Timestamp(3)
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @db.Timestamp(3)
  updatedAt             DateTime  @db.Timestamp(3)

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @db.Timestamp(3)
  createdAt  DateTime @db.Timestamp(3)
  updatedAt  DateTime @db.Timestamp(3)

  @@map("verification")
}

enum PlayGroundRule {
  PRIVATE
  PUBLIC
}

model PlayGround {
  id        String           @id
  name      String
  role      PlayGroundRule
  users     PlayGroundUser[]
  createdAt DateTime         @db.Timestamp(3)
  updatedAt DateTime         @db.Timestamp(3)

  @@map("playground")
}

enum PlayGroundUserRole {
  OWNER
  USER
}

model PlayGroundUser {
  id           String             @id
  user         User               @relation(fields: [userId], references: [id])
  userId       String
  playGround   PlayGround         @relation(fields: [playGroundId], references: [id])
  playGroundId String
  role         PlayGroundUserRole
  createdAt    DateTime           @db.Timestamp(3)
  updatedAt    DateTime           @db.Timestamp(3)

  @@map("playground_user")
}
