# EditorConfig helps maintain consistent coding styles across editors
# https://editorconfig.org

root = true

# Default settings for all files
[*]
# Use tabs for indentation for all files by default
indent_style = tab
# Use 2 spaces for indentation in all files by default
indent_size = 2
# Use LF for all files by default
end_of_line = lf
# Ensure UTF-8 encoding for all files
charset = utf-8
# Remove trailing whitespace in all files by default
trim_trailing_whitespace = true
# Ensure files end with a newline character by default
insert_final_newline = true
